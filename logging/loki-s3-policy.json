{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::prod-loki-chunks316",
        "arn:aws:s3:::prod-loki-ruler316",
        "arn:aws:s3:::prod-loki-admin316"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::prod-loki-chunks316/*",
        "arn:aws:s3:::prod-loki-ruler316/*",
        "arn:aws:s3:::prod-loki-admin316/*"
      ]
    }
  ]
}
